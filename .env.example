# ─── Gmail API ────────────────────────────────────────────────────────────────
# Path to downloaded OAuth2 credentials from Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json
# Path where token will be stored after first OAuth flow
GMAIL_TOKEN_PATH=token.json
# Gmail user ID (use "me" for authenticated user)
GMAIL_USER_ID=me
# Sender filter for Comp Sheet emails
GMAIL_TARGET_SENDER=research@lolcsecurities.com
# Subject keyword to match
GMAIL_SUBJECT_KEYWORD=Comp Sheet

# ─── File Storage ─────────────────────────────────────────────────────────────
# Directory for downloaded raw PDFs
DATA_DIR=data/raw
# Checkpoint file for backlog processor resume support
CHECKPOINT_FILE=data/checkpoints/backlog_checkpoint.json

# ─── HTTP / OneDrive ──────────────────────────────────────────────────────────
# Timeout in seconds for OneDrive download requests
ONEDRIVE_TIMEOUT=30

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# ─── Week 2: LLM Extraction ───────────────────────────────────────────────────
# Ollama base URL for local LLM (used first)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Claude API key (fallback if Ollama fails validation)
ANTHROPIC_API_KEY=

# ─── Week 3: Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cse_pipeline
# For docker-compose local dev
POSTGRES_DB=cse_pipeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Week 4: API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Week 5: AWS ──────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=cse-pipeline-pdfs
# Set these when deploying; use Secrets Manager in production
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
